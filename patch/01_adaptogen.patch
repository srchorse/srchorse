+--TEST--
+(adapt) cast supports class strings, autowired new expressions, and distinct keys
+--SKIPIF--
+<?php
+if (!function_exists('proc_open')) {
+    die('skip proc_open is required');
+}
+if (!function_exists('stream_socket_server')) {
+    die('skip stream_socket_server is required');
+}
+$server = @stream_socket_server('tcp://127.0.0.1:245', $errno, $errstr);
+if ($server === false) {
+    die('skip port 245 is unavailable');
+}
+fclose($server);
+?>
+--FILE--
+<?php
+$serverFile = __DIR__ . '/adaptogen_cast_server.php';
+$readyFile = __DIR__ . '/adaptogen_cast_server.ready';
+
+file_put_contents($serverFile, <<<'PHP'
+<?php
+$readyFile = __DIR__ . '/adaptogen_cast_server.ready';
+$server = stream_socket_server('tcp://127.0.0.1:245', $errno, $errstr);
+if ($server === false) {
+    exit(1);
+}
+file_put_contents($readyFile, 'ready');
+
+for ($i = 0; $i < 4; $i++) {
+    $conn = @stream_socket_accept($server, 10);
+    if ($conn === false) {
+        break;
+    }
+
+    $request = '';
+    while (!str_contains($request, "\r\n\r\n")) {
+        $chunk = fread($conn, 8192);
+        if ($chunk === '' || $chunk === false) {
+            break;
+        }
+        $request .= $chunk;
+    }
+
+    [$headers, $body] = explode("\r\n\r\n", $request, 2) + ['', ''];
+    if (preg_match('/Content-Length:\s*(\d+)/i', $headers, $matches)) {
+        $length = (int) $matches[1];
+        while (strlen($body) < $length) {
+            $chunk = fread($conn, $length - strlen($body));
+            if ($chunk === '' || $chunk === false) {
+                break;
+            }
+            $body .= $chunk;
+        }
+    }
+
+    parse_str($body, $post);
+
+    $responseBody = match ($post['command'] ?? '') {
+        'bool-one' => '1',
+        'bool-zero' => '0',
+        default => json_encode($post, JSON_THROW_ON_ERROR),
+    };
+
+    fwrite(
+        $conn,
+        "HTTP/1.1 200 OK\r\n"
+        . "Content-Type: text/plain\r\n"
+        . "Content-Length: " . strlen($responseBody) . "\r\n"
+        . "Connection: close\r\n\r\n"
+        . $responseBody
+    );
+    fclose($conn);
+}
+
+fclose($server);
+@unlink($readyFile);
+PHP);
+
+$descriptors = [
+    0 => ['pipe', 'r'],
+    1 => ['pipe', 'w'],
+    2 => ['pipe', 'w'],
+];
+$process = proc_open([PHP_BINARY, $serverFile], $descriptors, $pipes, __DIR__);
+if (!is_resource($process)) {
+    die("failed to start test server\n");
+}
+
+$started = false;
+for ($i = 0; $i < 50; $i++) {
+    if (file_exists($readyFile)) {
+        $started = true;
+        break;
+    }
+    usleep(100000);
+}
+
+if (!$started) {
+    proc_terminate($process);
+    proc_close($process);
+    die("server did not become ready\n");
+}
+
+final class AdaptogenTrue
+{
+    public function cron(): string
+    {
+        return '* * * * *';
+    }
+
+    public function command(): string
+    {
+        return 'bool-one';
+    }
+}
+
+final class AdaptogenFalse
+{
+    public function cron(): string
+    {
+        return '* * * * *';
+    }
+
+    public function command(): string
+    {
+        return 'bool-zero';
+    }
+}
+
+final class Service1
+{
+    public function getCron(): string
+    {
+        return '*/5 * * * *';
+    }
+}
+
+final class Service2
+{
+    public function getCommand(int $tenantId): string
+    {
+        return '/scripts/adaptogen.sh --tenant=' . $tenantId;
+    }
+}
+
+final class AdaptogenTenant
+{
+    public function __construct(
+        private Service1 $service1,
+        private Service2 $service2,
+        private int $tenantId,
+    ) {
+    }
+
+    public function cron(): string
+    {
+        return $this->service1->getCron();
+    }
+
+    public function command(): string
+    {
+        return $this->service2->getCommand($this->tenantId);
+    }
+
+    public function key(): string
+    {
+        return serialize($this->tenantId);
+    }
+}
+
+try {
+    var_dump((adapt) AdaptogenTrue::class);
+    var_dump((adapt) AdaptogenFalse::class);
+
+    $result1 = (adapt) new AdaptogenTenant(1);
+    $result2 = (adapt) new AdaptogenTenant(2);
+
+    var_dump($result1['cron']);
+    var_dump($result1['command']);
+    var_dump($result1['key'] !== $result2['key']);
+} finally {
+    proc_terminate($process);
+    proc_close($process);
+    @unlink($readyFile);
+    @unlink($serverFile);
+}
+?>
+--EXPECT--
+bool(true)
+bool(false)
+string(11) "*/5 * * * *"
+string(32) "/scripts/adaptogen.sh --tenant=1"
+bool(true)
