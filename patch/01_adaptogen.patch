+			continue;
+		}
+
+		dependency_ce = zend_adapt_resolve_parameter_class(constructor, i);
+		if (dependency_ce) {
+			if (zend_adapt_instantiate(&dependency, dependency_ce, NULL, depth + 1) == FAILURE) {
+				goto cleanup;
+			}
+			ZVAL_COPY_VALUE(&params[argc++], &dependency);
+			continue;
+		}
+
+		if (i < constructor->common.required_num_args) {
+			const char *param_name;
+
+			if (constructor->type == ZEND_USER_FUNCTION || (constructor->common.fn_flags & ZEND_ACC_USER_ARG_INFO)) {
+				param_name = ZSTR_VAL(constructor->common.arg_info[i].name);
+			} else {
+				param_name = constructor->internal_function.arg_info[i].name;
+			}
+			zend_throw_error(NULL, "Cannot autowire required constructor parameter $%s for %s",
+				param_name, ZSTR_VAL(ce->name));
+			goto cleanup;
+		}
+
+		break;
+	}
+
+	if (positional_index != positional_count) {
+		zend_throw_error(NULL, "Too many explicit constructor arguments for %s in the (adapt) cast", ZSTR_VAL(ce->name));
+		goto cleanup;
+	}
+
+	status = object_init_with_constructor(result, ce, argc, params, NULL);
+
+cleanup:
+	for (uint32_t i = 0; i < argc; i++) {
+		zval_ptr_dtor(&params[i]);
+	}
+	if (params) {
+		efree(params);
+	}
+	if (positional_args) {
+		efree(positional_args);
+	}
+	return status;
+}
+/* }}} */
+
+static zend_result zend_adapt_resolve_target_object(zval *object, zval *target, HashTable *explicit_args) /* {{{ */
+{
+	switch (Z_TYPE_P(target)) {
+		case IS_STRING: {
+			zend_class_entry *ce = zend_lookup_class(Z_STR_P(target));
+			if (!ce) {
+				zend_throw_error(NULL, "Cannot adapt unknown class %s", ZSTR_VAL(Z_STR_P(target)));
+				return FAILURE;
+			}
+			return zend_adapt_instantiate(object, ce, explicit_args, 0);
+		}
+
+		case IS_OBJECT:
+			ZVAL_OBJ_COPY(object, Z_OBJ_P(target));
+			return SUCCESS;
+
+		default:
+			zend_type_error("The (adapt) cast expects an object or class-string target, %s given",
+				zend_zval_value_name(target));
+			return FAILURE;
+	}
+}
+/* }}} */
+
+static zend_result zend_adapt_get_identity(zend_string **identity, zend_object *object, HashTable *explicit_args) /* {{{ */
+{
+	if (zend_hash_str_exists(&object->ce->function_table, "key", sizeof("key") - 1)) {
+		return zend_adapt_call_string_method(identity, object, "key");
+	}
+
+	return zend_adapt_fallback_identity(identity, object->ce, explicit_args);
+}
+/* }}} */
+
+static zend_result zend_adapt_execute(zval *return_value, zval *target, HashTable *explicit_args) /* {{{ */
+{
+	zval object;
+	zend_string *cron;
+	zend_string *command;
+	zend_string *identity;
+	zend_string *key;
+	zend_string *response;
+	zend_result status = FAILURE;
+
+	if (zend_adapt_resolve_target_object(&object, target, explicit_args) == FAILURE) {
+		return FAILURE;
+	}
+
+	if (zend_adapt_call_string_method(&cron, Z_OBJ(object), "cron") == FAILURE) {
+		goto cleanup_object;
+	}
+
+	if (zend_adapt_call_string_method(&command, Z_OBJ(object), "command") == FAILURE) {
+		zend_string_release(cron);
+		goto cleanup_object;
+	}
+
+	if (zend_adapt_get_identity(&identity, Z_OBJ(object), explicit_args) == FAILURE) {
+		zend_string_release(command);
+		zend_string_release(cron);
+		goto cleanup_object;
+	}
+
+	if (zend_adapt_hash_key(&key, Z_OBJCE(object), identity, cron, command) == FAILURE) {
+		zend_string_release(identity);
+		zend_string_release(command);
+		zend_string_release(cron);
+		goto cleanup_object;
+	}
+
+	if (zend_adapt_send_request(&response, cron, command, key) == FAILURE) {
+		zend_string_release(key);
+		zend_string_release(identity);
+		zend_string_release(command);
+		zend_string_release(cron);
+		goto cleanup_object;
+	}
+
+	status = zend_adapt_parse_response(return_value, response);
+
+	zend_string_release(response);
+	zend_string_release(key);
+	zend_string_release(identity);
+	zend_string_release(command);
+	zend_string_release(cron);
+
+cleanup_object:
+	zval_ptr_dtor(&object);
+	return status;
+}
+/* }}} */
+
+ZEND_FUNCTION(__zend_adapt)
+{
+	zval *target;
+
+	ZEND_PARSE_PARAMETERS_START(1, 1)
+		Z_PARAM_ZVAL(target)
+	ZEND_PARSE_PARAMETERS_END();
+
+	if (zend_adapt_execute(return_value, target, NULL) == FAILURE) {
+		RETURN_THROWS();
+	}
+}
+
+ZEND_FUNCTION(__zend_adapt_new)
+{
+	zend_string *class_name;
+	HashTable *args;
+	zval target;
+
+	ZEND_PARSE_PARAMETERS_START(2, 2)
+		Z_PARAM_STR(class_name)
+		Z_PARAM_ARRAY_HT(args)
+	ZEND_PARSE_PARAMETERS_END();
+
+	ZVAL_STR_COPY(&target, class_name);
+	if (zend_adapt_execute(return_value, &target, args) == FAILURE) {
+		zval_ptr_dtor(&target);
+		RETURN_THROWS();
+	}
+	zval_ptr_dtor(&target);
+}
