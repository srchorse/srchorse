+static zend_class_entry *zend_adapt_resolve_parameter_class(zend_function *function, uint32_t arg_num) /* {{{ */
+{
+	zend_type type = function->common.arg_info[arg_num].type;
+	zend_string *class_name;
+	uint32_t fetch_type;
+	zend_class_entry *ce;
+
+	if (!ZEND_TYPE_IS_SET(type) || ZEND_TYPE_HAS_LIST(type) || !ZEND_TYPE_HAS_NAME(type)) {
+		return NULL;
+	}
+
+	class_name = ZEND_TYPE_NAME(type);
+	fetch_type = zend_get_class_fetch_type(class_name);
+
+	if (fetch_type == ZEND_FETCH_CLASS_DEFAULT) {
+		return zend_lookup_class(class_name);
+	}
+
+	if (!function->common.scope) {
+		return NULL;
+	}
+
+	zend_class_entry *old_scope = EG(fake_scope);
+	EG(fake_scope) = function->common.scope;
+	ce = zend_fetch_class_by_name(class_name, NULL, fetch_type | ZEND_FETCH_CLASS_EXCEPTION);
+	EG(fake_scope) = old_scope;
+
+	return ce;
