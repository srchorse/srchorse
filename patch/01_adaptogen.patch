+static zend_result zend_adapt_parse_response(zval *return_value, zend_string *response) /* {{{ */
+{
+	const char *trimmed;
+	size_t trimmed_len;
+	zend_long lval;
+	double dval;
+	zval json_args[2];
+	zval json_result;
+
+	zend_adapt_trim_string(response, &trimmed, &trimmed_len);
+
+	if (trimmed_len != 0) {
+		uint8_t type = is_numeric_string(trimmed, trimmed_len, &lval, &dval, false);
+		if (type == IS_LONG) {
+			if (lval == 0 || lval == 1) {
+				ZVAL_BOOL(return_value, lval == 1);
+			} else {
+				ZVAL_LONG(return_value, lval);
+			}
+			return SUCCESS;
+		}
+		if (type == IS_DOUBLE) {
+			ZVAL_DOUBLE(return_value, dval);
+			return SUCCESS;
+		}
+	}
+
+	ZVAL_STR_COPY(&json_args[0], response);
+	ZVAL_TRUE(&json_args[1]);
+	if (zend_adapt_call_function(&json_result, "json_decode", 2, json_args) == SUCCESS) {
+		if (Z_TYPE(json_result) == IS_ARRAY) {
+			zval_ptr_dtor(&json_args[0]);
+			ZVAL_COPY_VALUE(return_value, &json_result);
+			return SUCCESS;
+		}
+		zval_ptr_dtor(&json_result);
+	}
+	zval_ptr_dtor(&json_args[0]);
+
+	if (trimmed_len == sizeof("true") - 1 && zend_binary_strcasecmp(trimmed, trimmed_len, "true", sizeof("true") - 1) == 0) {
+		ZVAL_TRUE(return_value);
+		return SUCCESS;
+	}
+	if (trimmed_len == sizeof("false") - 1 && zend_binary_strcasecmp(trimmed, trimmed_len, "false", sizeof("false") - 1) == 0) {
+		ZVAL_FALSE(return_value);
+		return SUCCESS;
+	}
+
+	ZVAL_STR_COPY(return_value, response);
+	return SUCCESS;
+}
+/* }}} */
