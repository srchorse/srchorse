+static zend_result zend_adapt_read_http_body(zend_string **body, zend_string *raw_response) /* {{{ */
+{
+	const char *data = ZSTR_VAL(raw_response);
+	const char *separator = zend_memnstr(data, "\r\n\r\n", sizeof("\r\n\r\n") - 1, data + ZSTR_LEN(raw_response));
+
+	if (separator) {
+		separator += sizeof("\r\n\r\n") - 1;
+		*body = zend_string_init(separator, ZSTR_LEN(raw_response) - (separator - data), 0);
+	} else {
+		*body = zend_string_copy(raw_response);
+	}
+
+	return SUCCESS;
+}
