+				return FAILURE;
+			}
+			positional_args[positional_count++] = arg;
+		} ZEND_HASH_FOREACH_END();
+	}
+
+	params = safe_emalloc(constructor->common.num_args ? constructor->common.num_args : 1, sizeof(zval), 0);
+
+	for (uint32_t i = 0; i < constructor->common.num_args; i++) {
+		zend_class_entry *dependency_ce;
+		zval dependency;
+
+		if (ZEND_ARG_IS_VARIADIC(&constructor->common.arg_info[i])) {
+			while (positional_index < positional_count) {
+				ZVAL_COPY(&params[argc++], positional_args[positional_index++]);
+			}
+			break;
+		}
+
