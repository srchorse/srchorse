+		return ZEND_TYPE_ALLOW_NULL(type);
+	}
+
+	if (Z_TYPE_P(arg) != IS_OBJECT) {
+		return false;
+	}
+
+	ce = zend_adapt_resolve_parameter_class(function, arg_num);
+	return ce && instanceof_function(Z_OBJCE_P(arg), ce);
