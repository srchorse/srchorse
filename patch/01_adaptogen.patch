+static void zend_adapt_trim_string(const zend_string *str, const char **start, size_t *len) /* {{{ */
+{
+	const char *s = ZSTR_VAL(str);
+	size_t l = ZSTR_LEN(str);
+
+	while (l > 0 && isspace((unsigned char) *s)) {
+		s++;
+		l--;
+	}
+	while (l > 0 && isspace((unsigned char) s[l - 1])) {
+		l--;
+	}
+
+	*start = s;
+	*len = l;
+}
+/* }}} */
