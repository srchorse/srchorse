#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: bin/build <php|python|nodejs|golang|chromium> [flags...]" >&2
}

if [ $# -lt 1 ]; then
  usage
  exit 1
fi

LANG="$1"
shift

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
UPSTREAM_SRC_DIR="$ROOT_DIR/src"
SRC_DIR="$ROOT_DIR/tmp"
PATCH_DIR="$ROOT_DIR/patch"
BUILD_ROOT="$ROOT_DIR/build"
LANG_KEY="$LANG"
BUILD_DIR="$BUILD_ROOT/$LANG_KEY"
INSTALL_DIR="$BUILD_DIR/install"
TARGET_SYMLINK="$ROOT_DIR/horse"

if [ ! -d "$UPSTREAM_SRC_DIR" ]; then
  echo "error: missing $UPSTREAM_SRC_DIR (run bin/clone first)" >&2
  exit 1
fi

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "error: required command not found: $1" >&2
    exit 1
  fi
}

reset_build_dir() {
  rm -rf "$BUILD_DIR"
  mkdir -p "$BUILD_DIR"
}

prepare_tmp_source() {
  local patch strip name

  rm -rf "$SRC_DIR"
  cp -a "$UPSTREAM_SRC_DIR" "$SRC_DIR"

  shopt -s nullglob
  local patch_files=("$PATCH_DIR"/*.patch)
  shopt -u nullglob

  if [ ${#patch_files[@]} -eq 0 ]; then
    return
  fi

  IFS=$'\n' local sorted=($(printf '%s\n' "${patch_files[@]}" | sort))
  unset IFS

  for patch in "${sorted[@]}"; do
    name="$(basename "$patch")"
    if ! echo "$name" | grep -qE '^[0-9]{2}_.+\.patch$'; then
      echo "error: invalid patch filename: $name (expected 01_name.patch)" >&2
      exit 1
    fi
    echo "Applying $name"
    strip=1
    if grep -qE '^diff --git a/src/' "$patch"; then
      strip=2
    fi
    git -C "$SRC_DIR" apply --recount -p"$strip" "$patch"
  done
}

JOBS=1
if command -v getconf >/dev/null 2>&1; then
  JOBS="$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)"
fi

prepare_tmp_source

case "$LANG" in
  python)
    LANG_KEY="python"
    BUILD_DIR="$BUILD_ROOT/$LANG_KEY"
    INSTALL_DIR="$BUILD_DIR/install"
    require_cmd make
    reset_build_dir
    if [ ! -f "$BUILD_DIR/Makefile" ]; then
      (cd "$BUILD_DIR" && "$SRC_DIR/configure" --prefix="$INSTALL_DIR" "$@")
    fi
    make -C "$BUILD_DIR" -j "$JOBS"
    make -C "$BUILD_DIR" install
    BUILT_BIN="$INSTALL_DIR/bin/python3"
    ;;
  php)
    LANG_KEY="php"
    BUILD_DIR="$BUILD_ROOT/$LANG_KEY"
    INSTALL_DIR="$BUILD_DIR/install"
    require_cmd make
    reset_build_dir
    if [ ! -x "$SRC_DIR/configure" ]; then
      (cd "$SRC_DIR" && ./buildconf --force)
    fi
    if [ ! -f "$BUILD_DIR/Makefile" ]; then
      (cd "$BUILD_DIR" && "$SRC_DIR/configure" --prefix="$INSTALL_DIR" "$@")
    fi
    make -C "$BUILD_DIR" -j "$JOBS"
    make -C "$BUILD_DIR" install
    BUILT_BIN="$INSTALL_DIR/bin/php"
    ;;
  node|nodejs)
    LANG_KEY="nodejs"
    BUILD_DIR="$BUILD_ROOT/$LANG_KEY"
    INSTALL_DIR="$BUILD_DIR/install"
    require_cmd make
    reset_build_dir
    if [ ! -f "$BUILD_DIR/Makefile" ]; then
      (cd "$BUILD_DIR" && "$SRC_DIR/configure" --prefix="$INSTALL_DIR" "$@")
    fi
    make -C "$BUILD_DIR" -j "$JOBS"
    make -C "$BUILD_DIR" install
    BUILT_BIN="$INSTALL_DIR/bin/node"
    ;;
  go|golang)
    LANG_KEY="golang"
    BUILD_DIR="$BUILD_ROOT/$LANG_KEY"
    INSTALL_DIR="$BUILD_DIR/install"
    reset_build_dir
    (cd "$SRC_DIR/src" && ./make.bash "$@")
    mkdir -p "$INSTALL_DIR/bin"
    cp -a "$SRC_DIR/bin/." "$INSTALL_DIR/bin/"
    BUILT_BIN="$INSTALL_DIR/bin/go"
    ;;
  chromium)
    LANG_KEY="chromium"
    BUILD_DIR="$BUILD_ROOT/$LANG_KEY"
    INSTALL_DIR="$BUILD_DIR/install"
    reset_build_dir
    if ! command -v gn >/dev/null 2>&1; then
      echo "error: required command not found: gn" >&2
      exit 1
    fi
    if ! command -v ninja >/dev/null 2>&1; then
      echo "error: required command not found: ninja" >&2
      exit 1
    fi
    OUT_DIR="$BUILD_DIR/out"
    mkdir -p "$OUT_DIR"
    (cd "$SRC_DIR" && gn gen "$OUT_DIR" "$@")
    ninja -C "$OUT_DIR" chrome
    if [ -x "$OUT_DIR/chrome" ]; then
      BUILT_BIN="$OUT_DIR/chrome"
    elif [ -x "$OUT_DIR/chrome-wrapper" ]; then
      BUILT_BIN="$OUT_DIR/chrome-wrapper"
    else
      echo "error: built Chromium binary not found in $OUT_DIR" >&2
      exit 1
    fi
    ;;
  *)
    echo "error: unknown language: $LANG" >&2
    usage
    exit 1
    ;;
 esac

if [ ! -x "$BUILT_BIN" ]; then
  echo "error: built binary not found at $BUILT_BIN" >&2
  exit 1
fi

ln -sfn "$BUILT_BIN" "$TARGET_SYMLINK"

echo "Built $LANG at $BUILT_BIN"
echo "Symlinked $TARGET_SYMLINK -> $BUILT_BIN"
